rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Phase 4: Validation Blueprints
    
    function isValidUser(data) {
      return data.keys().hasAll(['theme', 'updatedAt']) && 
             data.keys().size() == 2 &&
             data.theme is string && data.theme in ['light', 'dark', 'system'] &&
             data.updatedAt == request.time;
    }

    function isValidCartItem(data) {
      return data.keys().hasAll(['id', 'name', 'price', 'quantity']) &&
             data.id == data.id; // temporary simple check
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['type', 'message', 'read', 'timestamp']);
    }

    function isValidWishlistItem(data) {
      return data.keys().hasAll(['id', 'name', 'price']) &&
             data.id == data.id; // temporary simple check
    }

    // Match Blocks

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['theme', 'updatedAt']);
    }

    match /users/{userId}/cart/{itemId} {
      allow list: if isOwner(userId);
      allow get: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/notifications/{notifId} {
      allow list: if isOwner(userId);
      allow get: if isOwner(userId) && isValidId(notifId);
      allow create: if isOwner(userId) && isValidId(notifId);
      allow update: if isOwner(userId) && isValidId(notifId) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isOwner(userId) && isValidId(notifId);
    }

    match /users/{userId}/wishlist/{itemId} {
      allow list: if isOwner(userId);
      allow get: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if existing().userId == request.auth.uid;
    }

    match /users/{userId}/recentlyViewed/{itemId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/profile/info {
      allow read, write: if isOwner(userId);
    }

    match /system/connection_test {
      allow get: if isSignedIn();
    }
  }
}
